# Copy to .env (or export these) and run `icefold-runner`.
# All also accept the matching --flag.

# Runner token — generate it in the IceFold app (Nodes ▸ Connect a runner).
# The token encodes + signs your user id, so no server URL or user id is needed.
ICEFOLD_RUNNER_TOKEN=paste-your-token-here

# Stable id for this runner (default: hostname).
#ICEFOLD_RUNNER_ID=home-pc

# Scratch dir for staged inputs + ffmpeg products (default: ./icefold-runner-data).
#ICEFOLD_RUNNER_DIR=/var/lib/icefold-runner

# Self-hosting / dev only: point at a different IceFold server (default: the
# built-in production URL). ws(s):// or http(s):// both work.
#ICEFOLD_RUNNER_SERVER=ws://127.0.0.1:7000

# WebSocket keepalive ping cadence in seconds (default 20, clamped to [5, 90]).
# Keep it under any proxy/CDN idle timeout in front of the server so the link
# never goes idle and half-opens. Lower it if a strict front-end still drops you.
#ICEFOLD_RUNNER_KEEPALIVE_S=20
